ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=...
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

ARI_URL=http://localhost:8088
ARI_USER=baat_bot
ARI_PASSWORD=baat-1001

# RTP_HOST is the address Asterisk (inside Docker) uses to reach the Python app.
# On Mac/Windows Docker Desktop: host.docker.internal resolves to the host machine.
# Python app listens on 0.0.0.0:7000 — Asterisk sends ExternalMedia RTP here.
RTP_HOST=host.docker.internal
RTP_PORT=7000
